{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "includes": ["**", "!!**/__test__", "!**/public"],
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": { "noUselessSwitchCase": "off" },
      "style": {
        "useImportType": { "level": "warn", "options": { "style": "auto" } }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              ["react", "react/**", "react-*", "react-*/**"],
              ["redux", "redux-*", "@reduxjs/**"],
              [
                ":PACKAGE:",
                "!@lca/**",
                "!components/**",
                "!containers/**",
                "!ducks/**",
                "!hooks/**",
                "!types/**",
                "!utils",
                "!utils/**"
              ],
              ":BLANK_LINE:",
              "@material-ui/**",
              ":BLANK_LINE:",
              "@lca/**",
              ["components/**", "containers/**"],
              ["ducks/**", "hooks/**", "utils/**"],
              ":ALIAS:",
              ":PATH:"
            ]
          }
        }
      }
    }
  }
}
