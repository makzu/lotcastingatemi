{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/public", "!**/tmp"],
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noUselessSwitchCase": "off"
      },
      "correctness": {
        "useImportExtensions": "error"
      },
      "style": {
        "useConsistentArrayType": "on",

        "useImportType": { "level": "warn", "options": { "style": "auto" } },
        "useFragmentSyntax": "on"
      },
      "suspicious": {
        "noImportCycles": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              ["react", "react/**", "react-*", "react-*/**"],
              ["redux", "redux-*", "@reduxjs/**"],
              [":PACKAGE:", "!@lca/**"],
              ":BLANK_LINE:",
              "@material-ui/**",
              ":BLANK_LINE:",
              "@lca/**",
              ":ALIAS:",
              ":PATH:"
            ]
          }
        }
      }
    }
  }
}
