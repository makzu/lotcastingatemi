{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true, // TODO: remove this once all "import React from 'react'" statements are removed
    "baseUrl": "app/javascript/lca",
    "paths": {
      "@lca/*": ["*"],
      "Docs": ["../../../docs"],
      "Locales": ["../../../locales"]
    },
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    //"sourceMap": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "vendor", "public"],
  "compileOnSave": false
}
